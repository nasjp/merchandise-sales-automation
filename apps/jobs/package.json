{
  "name": "@merchandise/jobs",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"trigger/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "trigger:dev": "pnpm dlx trigger.dev@latest dev --config trigger.config.ts --env-file ../../.env.production"
  },
  "dependencies": {
    "@merchandise/db": "workspace:*",
    "@merchandise/domain": "workspace:*",
    "@merchandise/llm": "workspace:*",
    "@merchandise/mercari": "workspace:*",
    "@trigger.dev/sdk": "4.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
