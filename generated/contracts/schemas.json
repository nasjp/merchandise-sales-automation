{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "AndroidIngestPayload": {
      "type": "object",
      "properties": {
        "notificationId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "body": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "receivedAt": {
          "type": "string",
          "format": "date-time"
        },
        "sourcePackage": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        }
      },
      "required": [
        "title",
        "body"
      ],
      "additionalProperties": false
    },
    "AndroidIngestResponse": {
      "type": "object",
      "properties": {
        "eventId": {
          "type": "string"
        },
        "deduped": {
          "type": "boolean"
        },
        "queued": {
          "type": "boolean"
        }
      },
      "required": [
        "eventId",
        "deduped",
        "queued"
      ],
      "additionalProperties": false
    },
    "CandidateApprovePayload": {
      "type": "object",
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      },
      "additionalProperties": false
    },
    "CandidateRejectPayload": {
      "type": "object",
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      },
      "required": [
        "reason"
      ],
      "additionalProperties": false
    },
    "CandidateReviewResponse": {
      "type": "object",
      "properties": {
        "candidateId": {
          "type": "string"
        },
        "reviewState": {
          "type": "string",
          "enum": [
            "pending",
            "needs_review",
            "approved",
            "rejected",
            "excluded"
          ]
        },
        "reason": {
          "type": "string",
          "nullable": true
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "candidateId",
        "reviewState",
        "reason",
        "updatedAt"
      ],
      "additionalProperties": false
    },
    "TargetRefreshResponse": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        },
        "taskName": {
          "type": "string",
          "enum": [
            "pricing.recomputeSnapshot"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "queued"
          ]
        }
      },
      "required": [
        "runId",
        "targetId",
        "taskName",
        "status"
      ],
      "additionalProperties": false
    },
    "TriggerRunResponse": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        },
        "taskName": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "success",
            "failed"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finishedAt": {
          "type": "string",
          "format": "date-time",
          "nullable": true
        },
        "payload": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "runId",
        "taskName",
        "status",
        "startedAt",
        "finishedAt",
        "payload"
      ],
      "additionalProperties": false
    },
    "TriggerRunReprocessResponse": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        },
        "requeuedFromRunId": {
          "type": "string"
        },
        "taskName": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "queued"
          ]
        }
      },
      "required": [
        "runId",
        "requeuedFromRunId",
        "taskName",
        "status"
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
